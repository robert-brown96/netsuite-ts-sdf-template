{
  "compilerOptions": {
    /* Target & Environment */
    "target": "ES2020",                      /* Best fit for SuiteScript 2.1 (ES6+) */
    "module": "AMD",                         /* NetSuite uses AMD (define/require) */
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ESNext"],

    /* Paths & Outputs */
    "rootDir": "src/TypeScripts/idev-engineering-netsuite",
    "outDir": "src/FileCabinet/SuiteScripts/idev-engineering-netsuite",
    "baseUrl": ".",
    "paths": {
      "N": ["node_modules/@hitc/netsuite-types/N"],
      "N/*": ["node_modules/@hitc/netsuite-types/N/*"]
    },

    /* The "Rigor" Guardrails */
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    /* NetSuite Compatibility */
    "skipLibCheck": true,
    "noEmitOnError": true                    /* Don't generate JS if the TS has errors */
  },
  "include": ["src/TypeScripts/idev-engineering-netsuite/**/*"],
  "exclude": ["node_modules", "src/FileCabinet"]
}
